NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Upload limits (MB). MUST stay in sync with backend `app/core/config.py`:
#   MAX_UPLOAD_SIZE_CSV_MB / MAX_UPLOAD_SIZE_XLSX_MB / MAX_UPLOAD_SIZE_PDF_MB
# A mismatch is harmless for security (server enforces) but breaks UX:
# the client says «OK» and the user waits for the upload only to be told 413.
NEXT_PUBLIC_MAX_UPLOAD_CSV_MB=10
NEXT_PUBLIC_MAX_UPLOAD_XLSX_MB=10
NEXT_PUBLIC_MAX_UPLOAD_PDF_MB=25
