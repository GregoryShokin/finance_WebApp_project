lTag":"div"},"label":{"active":false},"slideLink":{"active":false},"image":{"src":"https://cdn.tbank.ru/static/pages/files/b1cb4535-4256-4e48-9577-83f92c0f56a7.png","alt":"","title":""},"button":{"text":"Открыть счёт","style":"mono","onClick":{"action":"goToBlock","guid":"df9dd23e-388d-472d-81ae-da8ffe9f8fd6"},"htmlTag":"div","ariaLabel":"Открыть счёт для расчётов в иностранной валюте"},"analytics":{"componentName":"","componentProductName":"","componentProductCategory":""}}],"analytics":{"componentName":"","componentProductName":"","componentProductCategory":""}},"meta":{"analytics":{"tracking":{"active":true,"trackingName":"desktopImageBottomPanel_9zdeanpz4jrc"}}},"projectTitle":"pwa-blocks","id":"26f7c85d-2231-4721-85a4-7d4fe5022ade","schemaId":"2e0ee65e-e2f6-497a-be21-927d4153fe8e"},{"content":[],"type":"desktopImagePlusText","version":"6.0","preloadingRoutesMenuStrategy":null,"render":{"npmVersion":"15.75.10"},"properties":{"background":{"style":"custom","color":"#f1eee8"},"image":{"alt":"","title":"","imageSize":"imageS","imageS":{"src":"https://cdn.tbank.ru/static/pages/files/3ab39bc5-ae8c-4111-8dec-a6e5338e1a2c.png"},"background":"#E4D7C1"},"imagePosition":"right","bullet":[{"title":{"text":"\u003Cp>Платежи в&nbsp;юанях с&nbsp;DGTL_COIN ещё выгоднее!\u003C/p>","htmlTag":"h4"},"subtitle":{"text":"\u003Cp>Получайте максимум выгоды с&nbsp;программой лояльности DGTL_COIN:\u003C/p>\n\u003Cul>\n  \u003Cli>Начисляем 1000&nbsp;баллов сразу после подключения к&nbsp;программе\u003C/li>\n  \u003Cli>За&nbsp;каждые 100&nbsp;000&nbsp;рублей в&nbsp;платежах вы&nbsp;зарабатываете 1&nbsp;балл\u003C/li>\n  \u003Cli>За&nbsp;каждые 10&nbsp;000&nbsp;юаней в&nbsp;платежах вы&nbsp;зарабатываете 1&nbsp;балл\u003C/li>\n  \u003Cli>Накопленные баллы обмениваются на&nbsp;скидку на&nbsp;услуги банка\u003C/li>\n\u003C/ul>","htmlTag":"div"}}],"analytics":{"componentName":"","componentProductName":"","componentProductCategory":""}},"projectTitle":"pwa-blocks","id":"bbd0761a-e6d8-445f-9ee3-