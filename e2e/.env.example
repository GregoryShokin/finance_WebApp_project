# E2E suite configuration. Copy to .env and adjust if your local stack uses different ports.
# All variables are read by global-setup.ts and playwright.config.ts via dotenv.

# Backend API base URL. Must respond to GET /health with {"status":"ok"}.
E2E_API_URL=http://localhost:8000/api/v1

# Frontend base URL. Used as Playwright `baseURL`.
E2E_FRONTEND_URL=http://localhost:3000

# Postgres URL — used only as a last-resort escape hatch in helpers/seed.ts when a
# test endpoint can't cover the case. Default points at the docker-compose db
# (external port 5433). Tests should prefer /_test endpoints over direct SQL.
E2E_DB_URL=postgresql://postgres:postgres@localhost:5433/finance

# Set to 1 to skip frontend health check in global-setup (useful when running only
# API-only specs while frontend is offline). Default: 0 (require frontend).
E2E_SKIP_FRONTEND_CHECK=0
